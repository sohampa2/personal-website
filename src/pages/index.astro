---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const latestPost = sortedPosts[0];
const latestProject = featuredProjects[0];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<Base title="Soham Agarwal — Mechanical Designer">
  <!-- NAV -->
  <nav>
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="nav-logo">S. Agarwal</a>
        <div class="nav-right">
          <ul class="nav-links">
            <li><a href="#projects">portfolio</a></li>
            <li><a href="#writing">writing</a></li>
            <li><a href="#about">about</a></li>
            <li><a href="#contact">contact</a></li>
          </ul>
          <button class="theme-toggle" id="themeBtn" aria-label="Toggle dark mode">[ dark ]</button>
          <button class="nav-hamburger" id="hamburger" aria-label="Open menu">menu</button>
        </div>
      </div>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="#projects">portfolio</a>
      <a href="#writing">writing</a>
      <a href="#about">about</a>
      <a href="#contact">contact</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left fade-in">
          <p class="hero-kicker">Mechanical Designer · Currently @ EarthSense</p>
          <h1 class="hero-name">SOHAM<br>AGARWAL</h1>
          <p class="hero-desc">
            I build systems that move with purpose — robots, mechanisms, and hardware that has to work in the real world.
            I work across the full design cycle: early CAD, simulation, and real-world testing.
            My process blends engineering rigor with design intent. I care about how things function,
            but also how they feel, assemble, and evolve.
          </p>
          <a href="#contact" class="btn-accent">get in touch →</a>
        </div>

        <div class="hero-right fade-in" style="transition-delay:0.12s">
          <div class="currently-block">
            <div class="panel-label">Currently</div>
            <div class="currently-item">
              <span class="ci-key">Building</span>
              <span class="ci-val">robots at EarthSense</span>
            </div>
            <div class="currently-item">
              <span class="ci-key">Running</span>
              <span class="ci-val">base miles — marathon block starts June</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EDITORIAL PANELS -->
  <section class="editorial">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Dispatches</span>
        <div class="section-rule"></div>
      </div>
      <div class="editorial-grid fade-in" style="transition-delay:0.08s">
        <div class="ed-panel">
          <div class="ed-tag">Latest Project</div>
          <h3 class="ed-title">{latestProject.data.title}</h3>
          <p class="ed-body">{latestProject.data.body.slice(0, 150)}…</p>
          <a href="#projects" class="ed-link">view project →</a>
        </div>
        <div class="ed-panel">
          <div class="ed-tag">Latest Writing</div>
          <h3 class="ed-title">{latestPost.data.title}</h3>
          <p class="ed-body">{latestPost.data.excerpt}</p>
          <a href="#writing" class="ed-link">read essay →</a>
        </div>
        <div class="ed-panel">
          <div class="ed-tag">On the Side</div>
          <h3 class="ed-title">Oil Paintings & Commissioned Work</h3>
          <p class="ed-body">When I'm not in the machine shop, I paint in oils. Portraits mainly — commissioned work includes Subhash Chandra Bose, Jiddu Krishnamurti, and the Afghan Girl.</p>
          <a href="#contact" class="ed-link">get in touch →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS (above writing) -->
  <section class="projects" id="projects">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Selected Work</span>
        <div class="section-rule"></div>
      </div>
      <div class="project-grid fade-in" style="transition-delay:0.08s">
        {featuredProjects.map(project => (
          <a href={`/projects/${project.id}`} class="project-card project-card-link">
            {project.data.cover && (
              <div class="project-card-img">
                <img src={project.data.cover} alt={project.data.title} loading="lazy" />
              </div>
            )}
            <div class="project-phase">
              <span class="phase-dot">●</span>{project.data.phase}
            </div>
            <div class="project-context">{project.data.context}</div>
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-body">{project.data.body.slice(0, 180)}…</p>
            <div class="tech-tags">
              {project.data.tags.map(tag => (
                <span class="tech-tag">{tag}</span>
              ))}
            </div>
            <div class="card-cta">view project →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WRITING -->
  <section class="writing" id="writing">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Writing</span>
        <div class="section-rule"></div>
      </div>
      <div class="writing-list fade-in" style="transition-delay:0.08s">
        {sortedPosts.map(post => (
          <div class="writing-item">
            <span class="writing-date">{formatDate(post.data.date)}</span>
            <span class="writing-title">{post.data.title}</span>
            <span class={`writing-tag${post.data.category === 'engineering' ? ' eng' : ''}`}>
              {post.data.category}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">About</span>
        <div class="section-rule"></div>
      </div>
      <div class="about-grid fade-in" style="transition-delay:0.08s">
        <div class="about-body">
          <p>I'm a mechanical designer focused on building systems that move with purpose. I work across the full design cycle — from early CAD and simulations to real-world testing.</p>
          <p>My process blends engineering rigor with design intent. I care about how things function, but also how they feel, assemble, and evolve. Each project is an opportunity to solve problems simply, precisely, and meaningfully.</p>
          <p>Currently building robots at EarthSense.</p>

          <div class="about-stats">
            <div class="about-stat-cell">
              <div class="about-stat-num">847</div>
              <div class="about-stat-label">Miles Run</div>
            </div>
            <div class="about-stat-cell">
              <div class="about-stat-num">10</div>
              <div class="about-stat-label">Countries Visited</div>
            </div>
            <div class="about-stat-cell">
              <div class="about-stat-num">~60</div>
              <div class="about-stat-label">Prints Rejected</div>
            </div>
            <div class="about-stat-cell">
              <div class="about-stat-num">30+</div>
              <div class="about-stat-label">Prototypes Iterated</div>
            </div>
            <div class="about-stat-cell">
              <div class="about-stat-num">400+</div>
              <div class="about-stat-label">Lifts Logged</div>
            </div>
            <div class="about-stat-cell">
              <div class="about-stat-num">12</div>
              <div class="about-stat-label">Trails Completed</div>
            </div>
          </div>
        </div>

        <div class="about-meta">
          <div class="about-meta-item">
            <span class="ci-key">Tools</span>
            <span class="ci-val">SolidWorks, Fusion 360, CATIA V5, ANSYS, LabVIEW, Python</span>
          </div>
          <div class="about-meta-item">
            <span class="ci-key">Manufacturing</span>
            <span class="ci-val">CNC Machining, Lathe, FDM/SLA/Onyx 3D Printing, Laser Cutting</span>
          </div>
          <div class="about-meta-item">
            <span class="ci-key">Also does</span>
            <span class="ci-val">Oil painting, commissioned portraits, screen printing</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact-section" id="contact">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Contact</span>
        <div class="section-rule"></div>
      </div>
      <div class="contact-block border-box fade-in" style="transition-delay:0.08s">
        <p class="contact-line">Open to full-time roles in mechanical design and product development.</p>
        <a href="mailto:soham@example.com" class="btn-accent">soham@example.com →</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <span class="footer-name">S. AGARWAL</span>
        <span class="footer-right">MECHANICAL DESIGNER · EARTHSENSE</span>
      </div>
    </div>
  </footer>
</Base>
