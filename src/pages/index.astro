---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTeardowns = await getCollection('teardowns');
const publishedTeardowns = allTeardowns
  .filter(t => !t.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const latestTeardown = publishedTeardowns[0];
const latestProject = featuredProjects[0];

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<Base title="Soham Agarwal — Mechanical Designer">
  <!-- NAV -->
  <nav>
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="nav-logo">S. Agarwal</a>
        <div class="nav-right">
          <ul class="nav-links">
            <li><a href="#projects">portfolio</a></li>
            <li><a href="#writing">teardowns</a></li>
            <li><a href="#about">about</a></li>
            <li><a href="#contact">contact</a></li>
          </ul>
          <button class="theme-toggle" id="themeBtn" aria-label="Toggle dark mode">[ dark ]</button>
          <button class="nav-hamburger" id="hamburger" aria-label="Open menu">menu</button>
        </div>
      </div>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="#projects">portfolio</a>
      <a href="#writing">teardowns</a>
      <a href="#about">about</a>
      <a href="#contact">contact</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left fade-in">
          <h1 class="hero-name">SOHAM<br>AGARWAL</h1>
          <p class="hero-desc">
            I build systems that move with purpose — robots, mechanisms, and hardware that has to work in the real world.
            I work across the full design cycle: early CAD, simulation, and real-world testing.
            My process blends engineering rigor with design intent. I care about how things function,
            but also how they feel, assemble, and evolve.
          </p>
          <a href="#contact" class="btn-green">get in touch →</a>
        </div>

        <div class="hero-right fade-in" style="transition-delay:0.12s">
          <div class="currently-block">
            <div class="panel-label">Currently</div>
            <div class="currently-item">
              <span class="ci-val">Building robots at EarthSense</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EDITORIAL PANELS -->
  <section class="editorial">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Latest</span>
        <div class="section-rule"></div>
      </div>
      <div class="latest-list fade-in" style="transition-delay:0.08s">
        <a href={`/projects/${latestProject.id}`} class="latest-entry">
          <span class="latest-tag">project</span>
          <span class="latest-title">{latestProject.data.title}</span>
          <span class="latest-arrow">→</span>
        </a>
        <a href="#writing" class="latest-entry">
          <span class="latest-tag">teardown</span>
          <span class="latest-title">{latestTeardown.data.product}</span>
          <span class="latest-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- PROJECTS (above writing) -->
  <section class="projects" style="display:none">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Selected Work</span>
        <div class="section-rule"></div>
      </div>
      <div class="project-grid fade-in" style="transition-delay:0.08s">
        {featuredProjects.map(project => (
          <a href={`/projects/${project.id}`} class="project-card project-card-link">
            {project.data.cover && (
              <div class="project-card-img">
                <img src={project.data.cover} alt={project.data.title} loading="lazy" />
              </div>
            )}
            <div class="project-phase">
              <span class="phase-dot">●</span>{project.data.phase}
            </div>
            <div class="project-context">{project.data.context}</div>
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-body">{(project.data.body ?? project.data.paragraphs?.[0] ?? '').slice(0, 180)}…</p>
            <div class="tech-tags">
              {project.data.tags.map(tag => (
                <span class="tech-tag">{tag}</span>
              ))}
            </div>
            <div class="card-cta">view project →</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROJECTS STRIP (experimental) -->
  <section class="projects-strip-section" id="projects">
    <div class="strip-header container fade-in">
      <span class="section-label">Selected Work — Strip View</span>
      <div class="section-rule"></div>
    </div>
    <div class="projects-strip fade-in" style="transition-delay:0.08s">
      {featuredProjects.filter(p => p.data.cover).map(project => (
        <a href={`/projects/${project.id}`} class="strip-card strip-card--full">
          <div class="wallet-tab">
            <span class="phase-dot">●</span>
            <span class="wallet-tab-title">{project.data.title}</span>
          </div>
          <div class="strip-img-wrap">
            <img src={project.data.cover} alt={project.data.title} loading="lazy" />
          </div>
          <div class="strip-full-content">
            <div class="project-phase"><span class="phase-dot">●</span>{project.data.phase}</div>
            {project.data.context && <div class="project-context">{project.data.context}</div>}
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-body">{(project.data.body ?? project.data.paragraphs?.[0] ?? '').slice(0, 80)}…</p>
            <div class="tech-tags">
              {project.data.tags.map(tag => <span class="tech-tag">{tag}</span>)}
            </div>
            <div class="card-cta">view project →</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- TEARDOWNS -->
  <section class="writing" id="writing">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Teardowns</span>
        <div class="section-rule"></div>
      </div>
      <div class="teardown-list fade-in" style="transition-delay:0.08s">
        {publishedTeardowns.map(t => (
          <div class="teardown-card" data-brand={t.id}>
            <div class="teardown-chrome">
              <span class="chrome-url">teardowns / {t.id}</span>
            </div>
            <div class="teardown-window"></div>
            <div class="teardown-footer">
              <h3 class="teardown-product">{t.data.product}</h3>
              <p class="teardown-summary">{t.data.summary}</p>
              <span class="teardown-cta">read teardown →</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">About</span>
        <div class="section-rule"></div>
      </div>
      <div class="about-top-grid fade-in" style="transition-delay:0.08s">
        <div class="about-body">
          <p>I'm a mechanical designer focused on building systems that move with purpose. I work across the full design cycle — from early CAD and simulations to real-world testing.</p>
          <p>My process blends engineering rigor with design intent. I care about how things function, but also how they feel, assemble, and evolve. Each project is an opportunity to solve problems simply, precisely, and meaningfully.</p>
          <p>Currently building robots at EarthSense.</p>
        </div>

        <div class="currently-block">
          <div class="panel-label">Stats</div>
          <div class="stats-2x2">
            <div class="stat-cell">
              <span class="ci-key">Prints Rejected</span>
              <span class="about-stat-num" data-count="306">306</span>
            </div>
            <div class="stat-cell">
              <span class="ci-key">Prototypes Iterated</span>
              <span class="about-stat-num" data-count="57">57</span>
            </div>
            <div class="stat-cell">
              <span class="ci-key">Lifts Logged</span>
              <span class="about-stat-num" data-count="47">47</span>
            </div>
            <div class="stat-cell">
              <span class="ci-key">Trails Completed</span>
              <span class="about-stat-num" data-count="28">28</span>
            </div>
          </div>
        </div>
      </div>

      <div class="skills-section fade-in" style="transition-delay:0.14s">
        <div class="skills-row">
          <div class="skills-label skills-label--green">Tools</div>
          <div class="skills-chips">
            <span class="skill-chip">SolidWorks</span>
            <span class="skill-chip">Fusion 360</span>
            <span class="skill-chip">CATIA V5</span>
            <span class="skill-chip">ANSYS</span>
            <span class="skill-chip">LabVIEW</span>
            <span class="skill-chip">Python</span>
          </div>
        </div>
        <div class="skills-row">
          <div class="skills-label skills-label--green">Manufacturing</div>
          <div class="skills-chips">
            <span class="skill-chip">CNC Machining</span>
            <span class="skill-chip">Lathe</span>
            <span class="skill-chip">FDM 3D Printing</span>
            <span class="skill-chip">SLA 3D Printing</span>
            <span class="skill-chip">Onyx 3D Printing</span>
            <span class="skill-chip">Laser Cutting</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact-section" id="contact">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Contact</span>
        <div class="section-rule"></div>
      </div>
      <div class="contact-block border-box fade-in" style="transition-delay:0.08s">
        <p class="contact-line">Open to full-time roles in mechanical design and product development.</p>
        <a href="mailto:a.soham703@gmail.com" class="btn-green">get in touch →</a>
      </div>
    </div>
  </section>

  <!-- WALLET STACK HINT -->
  <p class="wallet-hint container" id="walletHint" style="display:none">tap a card to bring it forward</p>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <span class="footer-name">S. AGARWAL</span>
        <span class="footer-right">MECHANICAL DESIGNER · EARTHSENSE</span>
      </div>
    </div>
  </footer>

<script>
(function () {
  var MOBILE_BP = 640;
  var TAB_H     = 52;

  var strip = document.querySelector('.projects-strip');
  if (!strip) return;

  var cards  = Array.from(strip.querySelectorAll('.strip-card--full'));
  var hint   = document.getElementById('walletHint');
  var active = 0;

  // ── Touch scroll detection ──────────────────────────────
  var touchStartY = 0;
  var isScrolling = false;

  document.addEventListener('touchstart', function (e) {
    touchStartY = e.touches[0].clientY;
    isScrolling = false;
  }, { passive: true });

  document.addEventListener('touchmove', function (e) {
    if (Math.abs(e.touches[0].clientY - touchStartY) > 8) isScrolling = true;
  }, { passive: true });

  // ── Height helpers ──────────────────────────────────────
  // Measure a card's full natural height without showing the transition.
  function measureFull(card) {
    var prev = card.style.height;
    card.style.transition = 'none';
    card.style.height     = 'auto';
    var h = card.scrollHeight;
    card.style.height     = prev;
    card.style.transition = '';
    return h;
  }

  function collapse(card) {
    card.style.height = TAB_H + 'px';
    card.classList.remove('wallet-active');
  }

  function expand(card) {
    card.classList.add('wallet-active');
    var fullH = measureFull(card);
    // Force the browser to commit the current (collapsed) height,
    // then animate to the measured full height in the next frame.
    card.getBoundingClientRect();
    requestAnimationFrame(function () {
      card.style.height = fullH + 'px';
      // Let the expansion get underway, then smoothly scroll it to center.
      setTimeout(function () {
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    });
  }

  function activate(i) {
    collapse(cards[active]);
    active = i;
    expand(cards[active]);
  }

  // ── Init / reset ────────────────────────────────────────
  function initMobile() {
    active = 0;
    cards.forEach(function (c) {
      c.style.transition = 'none';
      c.style.height     = TAB_H + 'px';
      c.classList.remove('wallet-active');
    });
    // Open first card immediately, no animation
    cards[0].classList.add('wallet-active');
    cards[0].style.height = cards[0].scrollHeight + 'px';
    // Re-enable transitions after paint
    requestAnimationFrame(function () {
      cards.forEach(function (c) { c.style.transition = ''; });
    });
    if (hint) hint.style.display = 'block';
  }

  function resetDesktop() {
    cards.forEach(function (c) {
      c.classList.remove('wallet-active');
      c.style.height     = '';
      c.style.transition = '';
    });
    if (hint) hint.style.display = 'none';
  }

  // ── Click / tap handler ─────────────────────────────────
  cards.forEach(function (card, i) {
    card.addEventListener('click', function (e) {
      if (window.innerWidth > MOBILE_BP) return;
      if (isScrolling) { e.preventDefault(); return; }
      if (i !== active) {
        e.preventDefault();
        activate(i);
      }
      // active card → let the <a> navigate
    });
  });

  if (window.innerWidth <= MOBILE_BP) initMobile();

  window.addEventListener('resize', function () {
    if (window.innerWidth <= MOBILE_BP) {
      if (!cards.some(function (c) { return c.classList.contains('wallet-active'); })) {
        initMobile();
      }
    } else {
      resetDesktop();
    }
  });
})();
</script>
</Base>
